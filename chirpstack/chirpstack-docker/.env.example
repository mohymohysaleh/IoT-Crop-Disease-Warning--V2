# gateway_activator.py, node_simulator.py, simulate_uplink.py — MUST hit Mosquitto in Docker compose.
# This repo maps host 1884 -> container 1883 (see docker-compose.yml mosquitto ports).
MQTT_HOST=localhost
MQTT_PORT=1884

# On Windows only: if Docker still uses plain 1883:1883, set MQTT_PORT=1883 instead.

# Optional: only for scripts/Reset-ChirpStackPostgres.ps1 -Force (stdin password); unset after run.
# CHIRPSTACK_BOOTSTRAP_PASSWORD=

# Copy to ".env" in this same folder (docker compose + Python simulators load it).
#   PowerShell: Copy-Item .env.example .env
# Never commit real passwords or ThingsBoard/JWT tokens.

# --- ThingsBoard device MQTT (OTA sidecars started by run_all_nodes.py) ---
THINGSBOARD_MQTT_HOST=localhost
THINGSBOARD_MQTT_PORT=11883

# 1 = start TB sidecars when devices.json has real access tokens; 0 = LoRa only (no TB warnings)
ENABLE_TB_SIDECARS=1

# Set to 1/true to force FAILED fw_state in the TB sidecar (rollback demo)
TB_OTA_SIMULATE_FAIL=0

# --- ChirpStack REST (optional; e.g. external API scripts) ---
CHIRPSTACK_API_URL=http://localhost:8090/api
CHIRPSTACK_REST_TOKEN=
# ``simulate_uplink.py`` uses MQTT + config/devices.json — no REST token needed.

# --- ThingsBoard REST (rollback_watchdog.py + chirpstack_tb_bridge.py) ---
TB_URL=http://localhost:9090
TB_USERNAME=tenant@thingsboard.org
TB_PASSWORD=
# Optional UUIDs; if empty, bridge resolves profiles named Zone1_Sensor / Zone2_Sensor
TB_ZONE1_PROFILE_ID=
TB_ZONE2_PROFILE_ID=
# TB_USERNAME / TB_PASSWORD must be a Tenant Administrator (e.g. tenant@thingsboard.org), not sysadmin.
# chirpstack_tb_bridge.py (CE): subscribe Mosquitto → HTTP telemetry. Host-run: keep MQTT_* + TB_URL localhost.
# Docker Compose service tb-chirpstack-bridge overrides TB_URL and MQTT_* to in-network hostnames.

# --- Simulator tuning (run_all_nodes.py) ---
SIM_TELEMETRY_INTERVAL=300
SIM_RNG_SEED=453
